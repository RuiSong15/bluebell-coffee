<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <title>Menu – Bluebell Coffee</title>
  <link rel="stylesheet" href="/style.css"/>
</head>
<body>

  <h1>Bluebell Coffee</h1>
  <h3>Where Every Cup Blooms</h3>

  <nav>
    <a href="/">Home</a>
    <a href="/drinks">Menu</a>
    <a href="/search">Search</a>
    <a href="/drinks/add">+ Add Drink</a>
  </nav>

  <% if (message) { %>
    <div style="background:#e6f4e6; border:1px solid #7ac47a; color:#256029; padding:12px 16px; border-radius:8px; margin-bottom:16px;">
      <%= decodeURIComponent(message) %>
    </div>
  <% } %>

  <div class="controls">
    <% categories.forEach(cat => { %>
      <a href="/drinks?category=<%= encodeURIComponent(cat) %>"
         style="padding:10px 16px; background:<%= selectedCategory===cat ? '#1a2d4a' : '#2e5090' %>; color:white; border-radius:8px; text-decoration:none; font-size:14px;">
        <%= cat %>
      </a>
    <% }) %>
    <a href="/drinks"
       style="padding:10px 16px; background:<%= selectedCategory==='all' ? '#1a2d4a' : '#6b9bd2' %>; color:white; border-radius:8px; text-decoration:none; font-size:14px;">
      All
    </a>
  </div>

  <div id="dashboard">
    <p>Showing <%= drinks.length %> records (from Neon PostgreSQL)</p>
    <p>Category: <%= selectedCategory === 'all' ? 'All' : selectedCategory %></p>
  </div>

  <% if (drinks.length === 0) { %>
    <div class="no-results"><p>No records found in this category.</p></div>
  <% } else { %>
    <% const slugify = n => n.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, ''); %>
    <table>
      <tr>
        <th>ID</th>
        <th></th>
        <th>Item Name</th>
        <th>Category</th>
        <th>Size</th>
        <th>Price</th>
        <th>Type</th>
        <th>Ingredients</th>
        <th>Actions</th>
      </tr>
      <% drinks.forEach(drink => { %>
      <tr>
        <td><%= drink.id %></td>
        <td><img class="thumb" src="/images/<%= slugify(drink.name) %>.svg" alt="" onerror="this.style.display='none'"/></td>
        <td><strong><%= drink.name %></strong></td>
        <td><%= drink.category %></td>
        <td><%= drink.size %></td>
        <td>$<%= drink.price.toFixed(2) %></td>
        <td><%= drink.order_type %></td>
        <td><%= (drink.ingredients || []).join(', ') || 'N/A' %></td>
        <td style="white-space:nowrap;">
          <a href="/drinks/<%= drink.id %>/edit"
             style="padding:4px 10px; background:#2e5090; color:white; border-radius:6px; text-decoration:none; font-size:12px;">Edit</a>
          <form method="POST" action="/drinks/<%= drink.id %>/delete" style="display:inline;"
                onsubmit="return confirm('Remove &quot;<%= drink.name %>&quot; (ID <%= drink.id %>) from the menu? This cannot be undone.');">
            <button type="submit"
                    style="padding:4px 10px; background:#b23b3b; color:white; border:none; border-radius:6px; font-size:12px; cursor:pointer;">Delete</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </table>
  <% } %>

</body>
</html>

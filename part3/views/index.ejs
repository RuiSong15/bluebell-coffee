<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>Bluebell Coffee</title>
  <link rel="stylesheet" href="/style.css"/>
</head>
<body>

  <header class="hero">
    <img src="/images/hero.svg" alt="" class="hero-bg"/>
    <div class="hero-text">
      <h1>🫐 Bluebell Coffee</h1>
      <h3>Where Every Cup Blooms</h3>
      <nav>
        <a href="/">Home</a>
        <a href="/drinks">Menu</a>
        <a href="/search">Search</a>
        <a href="/drinks/add">+ Add Drink</a>
      </nav>
    </div>
  </header>

  <div class="controls">
    <input type="text" id="searchInput" placeholder="🔍 Search drinks, categories, ingredients..."/>
    <select id="sortSelect">
      <option value="">Sort By</option>
      <option value="nameAsc">Name A–Z</option>
      <option value="nameDesc">Name Z–A</option>
      <option value="priceAsc">Price Low → High</option>
      <option value="priceDesc">Price High → Low</option>
      <option value="popDesc">Most Popular</option>
    </select>
    <button id="resetBtn">✕ Reset</button>
  </div>

  <div id="dashboard">
    <p id="totalItems"></p>
    <p id="categoryName"></p>
  </div>

  <p id="count"></p>
  <div class="cards" id="cards"></div>

  <script src="/app.js"></script>
</body>
</html>

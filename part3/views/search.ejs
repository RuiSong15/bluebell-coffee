<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <title>Search – Bluebell Coffee</title>
  <link rel="stylesheet" href="/style.css"/>
</head>
<body>

  <h1>Bluebell Coffee</h1>
  <h3>Where Every Cup Blooms</h3>

  <nav>
    <a href="/">Home</a>
    <a href="/drinks">Menu</a>
    <a href="/search">Search</a>
  </nav>

  <form method="POST" action="/search">
    <div class="controls">
      <input type="text" name="keyword" placeholder="🔍 Search by name or category..."
             value="<%= keyword %>"/>
      <button type="submit">Search</button>
      <a href="/search" style="padding:10px 20px; background:#6b9bd2; color:white; border-radius:8px; text-decoration:none; font-size:14px;">✕ Reset</a>
    </div>
  </form>

  <% if (error) { %>
    <div class="error"><%= error %></div>
  <% } %>

  <div id="dashboard">
    <% if (keyword && !error) { %>
      <p>Found <strong><%= results.length %></strong> result(s) for "<%= keyword %>"</p>
    <% } %>
  </div>

  <% if (keyword && !error && results.length === 0) { %>
    <div class="no-results">
      <p>😔 No orders found for "<%= keyword %>". Try a different keyword.</p>
    </div>
  <% } %>

  <% if (results.length > 0) { %>
    <% const slugify = n => n.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, ''); %>
    <table>
      <tr>
        <th>Order ID</th>
        <th></th>
        <th>Item Name</th>
        <th>Category</th>
        <th>Size</th>
        <th>Price</th>
        <th>Type</th>
        <th>Ingredients</th>
      </tr>
      <% results.forEach(drink => { %>
      <tr>
        <td><%= drink.order_id %></td>
        <td><img class="thumb" src="/images/<%= slugify(drink.name) %>.svg" alt="" onerror="this.style.display='none'"/></td>
        <td><strong><%= drink.name %></strong></td>
        <td><%= drink.category %></td>
        <td><%= drink.size %></td>
        <td>$<%= drink.price.toFixed(2) %></td>
        <td><%= drink.order_type %></td>
        <td><%= drink.ingredients.join(', ') || 'N/A' %></td>
      </tr>
      <% }) %>
    </table>
  <% } %>

</body>
</html>
